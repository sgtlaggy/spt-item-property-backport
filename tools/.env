# Path to Tarkov.Dev GraphQL query results
# Should contain ‘items.json’, ‘quests.json’
export TARKOV_DEV_FILES=

# Path to SPT/SPT_Data/database
# Should contain ‘globals.json’
export SPT_DB=

# Path to SPT/SPT_Data/database/templates
# Should contain ‘handbook.json’, ‘items.json’, ‘prices.json’, ‘quests.json’
export SPT_DB_TEMPLATES=

# Path to SPT/user/mods/WTT-ContentBackport/db/CustomItems
# Should contain many ‘.json’ files
export WTT_BACKPORT_DB=

# Path to final processed data files
export OUT_DIR=
